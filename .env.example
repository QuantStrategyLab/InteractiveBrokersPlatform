# Interactive Brokers Platform - Required Environment Variables

# ── Runtime Target (REQUIRED) ──
RUNTIME_TARGET_JSON={"platform_id":"interactive_brokers","strategy_profile":"global_etf_rotation","execution_mode":"live","account_scope":"paper","dry_run_only":true}

# ── IBKR Connection ──
IBKR_ACCOUNT_IDS=U123456
IBKR_GATEWAY_MODE=paper
IBKR_GATEWAY_IP_MODE=internal
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4001
IB_CLIENT_ID=1
IB_CONNECT_TIMEOUT_SECONDS=60

# ── Notification ──
TELEGRAM_TOKEN=<from-secret-manager>
GLOBAL_TELEGRAM_CHAT_ID=
NOTIFY_LANG=zh

# ── Execution Control ──
IBKR_DRY_RUN_ONLY=false
IBKR_FORCE_RUN=false

# ── Execution Report ──
EXECUTION_REPORT_OUTPUT_DIR=/tmp/quant_runtime_reports
EXECUTION_REPORT_GCS_URI=gs://qsl-runtime-logs-shared/execution-reports
